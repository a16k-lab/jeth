{
  "name": "jeth-syntax",
  "displayName": "JETH Syntax",
  "description": "Syntax highlighting and the JETH file icon for .jeth files - a TypeScript-subset smart-contract language compiling to EVM.",
  "version": "0.3.0",
  "publisher": "jeth",
  "private": true,
  "license": "MIT",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "icon": "icons/jeth-orange-icon-1024.png",
  "contributes": {
    "languages": [
      {
        "id": "jeth",
        "aliases": [
          "JETH",
          "jeth"
        ],
        "extensions": [
          ".jeth"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/jeth-orange-icon-128.png",
          "dark": "./icons/jeth-orange-icon-128.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "jeth",
        "scopeName": "source.jeth",
        "path": "./syntaxes/jeth.tmLanguage.json"
      },
      {
        "scopeName": "jeth.injection",
        "path": "./syntaxes/jeth.injection.json",
        "injectTo": [
          "source.jeth"
        ]
      }
    ]
  }
}
