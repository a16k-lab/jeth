{
  "name": "jeth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.7",
  "engines": {
    "node": ">=22.22.2"
  },
  "description": "JETH - a TypeScript-subset smart-contract language compiling to EVM bytecode via Yul",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:changed": "vitest run --changed",
    "jethc": "tsx src/cli.ts",
    "docs:build": "tsx scripts/build-docs.mts",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "version-packages": "changeset version",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "license": "MIT",
  "dependencies": {
    "@ethereumjs/block": "^10.1.2",
    "@ethereumjs/common": "^10.1.2",
    "@ethereumjs/evm": "^10.1.2",
    "@ethereumjs/statemanager": "^10.1.2",
    "@ethereumjs/util": "^10.1.2",
    "ethereum-cryptography": "^3.2.0",
    "solc": "^0.8.35",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@types/node": "^25.9.3",
    "kzg-wasm": "^1.0.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "vitest": "^4.1.9"
  }
}
