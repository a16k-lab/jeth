// scenario struct-with-fixed-array-field
type Rec = { id: u64; data: Arr<u256, 2>; };

class StructFixedArrField {
  recs: mapping<u256, Rec[]>;   // slot 0
  sentinel: u256;               // slot 1

  // grow + populate: push a zero Rec, then write its fields (covers push + RMW)
  addRec(k: u256, id: u64, d0: u256, d1: u256): External<void> {
    this.recs[k].push();
    let i: u256 = this.recs[k].length - 1n;
    this.recs[k][i].id = id;
    this.recs[k][i].data[0n] = d0;
    this.recs[k][i].data[1n] = d1;
  }
  pushEmpty(k: u256): External<void> { this.recs[k].push(); }
  popRec(k: u256): External<void> { this.recs[k].pop(); }

  setId(k: u256, i: u256, v: u64): External<void> { this.recs[k][i].id = v; }
  setData(k: u256, i: u256, j: u256, v: u256): External<void> { this.recs[k][i].data[j] = v; }

  get recLen(k: u256): External<u256> { return this.recs[k].length; }
  get getId(k: u256, i: u256): External<u64> { return this.recs[k][i].id; }
  get getData(k: u256, i: u256, j: u256): External<u256> { return this.recs[k][i].data[j]; }
}
