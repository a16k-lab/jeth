// The Phase 1 proof contract. JS syntax, EVM/Solidity semantics.
class Counter {
  count: u256 = 0n;

  increment(): External<void> {
    this.count += 1n; // checked uint256 add -> SSTORE at slot 0
  }

  add(delta: u256): External<void> {
    this.count += delta;
  }

  get current(): External<u256> {
    return this.count;
  }
}
